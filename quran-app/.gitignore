# .gitignore - Git ignore patterns

# Environment files
.env
.env.local
.env.*.local

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Node modules (if using node)
node_modules/
package-lock.json
npm-debug.log
yarn-error.log

# Build output
dist/
build/
out/

# Temporary files
*.tmp
*.temp
*.log
*.cache

# OS specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
desktop.ini

# Browser dev tools
.devtools/

# Testing
coverage/
.nyc_output/

# Deployment
*.zip
*.tar.gz
deploy.log

# Debug
debug/
*.debug

# Local development
local/
test.html
temp/
